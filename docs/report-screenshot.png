
    <!DOCTYPE html>
    <html>
    <head>
        <title>Compliance Report</title>
        <style>
            body { font-family: Arial; margin: 40px; background: #f5f5f5; }
            h1 { color: #2c3e50; }
            table { width: 100%; border-collapse: collapse; background: white; }
            th { background: #2c3e50; color: white; padding: 12px; text-align: left; }
            td { padding: 12px; border-bottom: 1px solid #ddd; }
            .summary { display: flex; gap: 20px; margin: 20px 0; }
            .card { padding: 20px; border-radius: 8px; color: white; min-width: 150px; text-align: center; }
            .green { background: #2ecc71; }
            .red { background: #e74c3c; }
        </style>
    </head>
    <body>
        <h1>🔐 Compliance Report</h1>
        <p>Generated: 2026-04-26 20:46:44</p>
        <div class="summary">
            <div class="card green"><h2>0</h2><p>Compliant</p></div>
            <div class="card red"><h2>3</h2><p>Non-Compliant</p></div>
        </div>
        <table>
            <tr><th>Rule</th><th>Status</th><th>Timestamp</th></tr>
            
        <tr>
            <td>❌ encrypted-volumes</td>
            <td style="color:#e74c3c; font-weight:bold">INSUFFICIENT_DATA</td>
            <td>2026-04-26 20:46:44</td>
        </tr>
        <tr>
            <td>❌ mfa-enabled-for-iam-console-access</td>
            <td style="color:#e74c3c; font-weight:bold">INSUFFICIENT_DATA</td>
            <td>2026-04-26 20:46:44</td>
        </tr>
        <tr>
            <td>❌ s3-bucket-public-read-prohibited</td>
            <td style="color:#e74c3c; font-weight:bold">NON_COMPLIANT</td>
            <td>2026-04-26 20:46:44</td>
        </tr>
        </table>
    </body>
    </html>